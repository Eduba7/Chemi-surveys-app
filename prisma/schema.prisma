// Chemi Surveys & Mapping Consultants — Database Schema
// Run: npx prisma migrate dev --name init
// Provider: POSTGRESQL (compatible with Supabase's on Postgres bridge(e.g Render)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum ConsultationStatus {
  BOOKED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ---------------------------------------------------------------------------
// USERS — Firm staff / admin accounts (John, Anthony, John Malele, etc.)
// ---------------------------------------------------------------------------
model User {
  id           Int        @id @default(autoincrement())
  fullName     String     @map("full_name")
  email        String     @unique
  phone        String?
  role         Role       @default(STAFF)
  passwordHash String     @map("password_hash")
  jobTitle     String?    @map("job_title") // e.g. "Land Surveyor", "Fieldwork Operations"
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  consultationsHandled Consultation[] @relation("HandledBy")
  auditLogs            AuditLog[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// CLIENTS — Added manually by the surveyor through the dashboard UI.
// Starts empty in production; no seed data for client records.
// ---------------------------------------------------------------------------
model Client {
  id           Int            @id @default(autoincrement())
  nameOrCompany String        @map("name_or_company")
  email        String?
  phone        String?
  logoUrl      String?        @map("logo_url") // Supabase Storage URL
  notes        String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  consultations Consultation[]
  projects      Project[]

  @@map("clients")
}

// ---------------------------------------------------------------------------
// SERVICES — Catalogue of survey services offered by the firm
// ---------------------------------------------------------------------------
model Service {
  id          Int      @id @default(autoincrement())
  name        String   @map("service_name")
  description String?  @db.Text
  iconKey     String?  @map("icon_key") // maps to a Tabler icon name on the frontend
  createdAt   DateTime @default(now()) @map("created_at")

  consultations Consultation[]

  @@map("services")
}

// ---------------------------------------------------------------------------
// CONSULTATIONS — Appointments / bookings. Drives Dashboard, Calendar,
// Today's Schedule, Upcoming Tasks, and the Consultations status filters.
// ---------------------------------------------------------------------------
model Consultation {
  id            Int                @id @default(autoincrement())
  clientId      Int                @map("client_id")
  serviceId     Int                @map("service_id")
  handledById   Int?               @map("handled_by_id")
  scheduledTime DateTime           @map("scheduled_time")
  location      String?
  status        ConsultationStatus @default(BOOKED)
  source        String?            // e.g. "Dashboard", "Phone", "Walk-in"
  notes         String?            @db.Text
  isToday       Boolean            @default(false) @map("is_today") // distinguishes Today's Schedule vs Upcoming
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
  handledBy User?    @relation("HandledBy", fields: [handledById], references: [id])

  @@index([clientId])
  @@index([serviceId])
  @@index([status])
  @@index([scheduledTime])
  @@map("consultations")
}

// ---------------------------------------------------------------------------
// PROJECTS — The 12-slot "My Projects" portfolio grid. Starts fully empty;
// the surveyor fills each slot with their own completed work.
// ---------------------------------------------------------------------------
model Project {
  id             Int       @id @default(autoincrement())
  slotIndex      Int       @map("slot_index") // 0–11, pins position in the 12-grid
  projectTitle   String    @map("project_title")
  imageUrl       String?   @map("image_url") // Supabase Storage URL
  completionDate DateTime? @map("completion_date")
  clientId       Int?      @map("client_id")
  description    String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id])

  @@unique([slotIndex])
  @@map("projects")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS — Email/SMS simulation log for reminders & status changes
// ---------------------------------------------------------------------------
model Notification {
  id        Int      @id @default(autoincrement())
  channel   String   // "EMAIL" | "SMS"
  recipient String
  subject   String?
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING | SENT | FAILED
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ---------------------------------------------------------------------------
// AUDIT LOG — Tracks who changed what (e.g. status updates on consultations)
// ---------------------------------------------------------------------------
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String   // e.g. "UPDATE_CONSULTATION_STATUS"
  entity    String   // e.g. "Consultation"
  entityId  Int      @map("entity_id")
  detail    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
