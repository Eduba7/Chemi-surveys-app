# --- Database ---
# MySQL connection string. Works with Supabase's MySQL bridge, PlanetScale,
# Railway, or a local MySQL instance.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/chemi_surveys"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"

# --- Server ---
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
VITE_API_URL="http://localhost:4000"

# --- Storage (Supabase Storage for client logos & project images) ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_BUCKET="chemi-surveys-media"

# --- Notifications (simulation — wire up real providers later) ---
NOTIFY_EMAIL_FROM="no-reply@chemisurveys.co.ke"
NOTIFY_SMS_SENDER_ID="CHEMI"
